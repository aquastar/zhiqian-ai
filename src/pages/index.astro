const selectedFilters = [
  { key: 'all', label: 'All' },
  { key: 'cross-network', label: 'Cross-Network' },
  { key: 'uq', label: 'UQ' },
  { key: 'unified-graph', label: 'Spectral Graph' },
  { key: 'spatial', label: 'Spatial' },
  { key: 'software-hardware', label: 'Software/Hardware' },
  { key: 'symbolic', label: 'Symbolic' },
  { key: 'materials', label: 'Material Sci.' },
  { key: 'music', label: 'Music' },
];

const selectedCategoryLabels = Object.fromEntries(
  selectedFilters.filter((filter) => filter.key !== 'all').map((filter) => [filter.key, filter.label])
);

const coreRankings = {
  AAAI: 'CORE A*',
  KDD: 'CORE A*',
  WWW: 'CORE A*',
  SDM: 'CORE A',
  ICDM: 'CORE A',
  SIGSPATIAL: 'CORE A',
  DATE: 'CORE A',
  BigData: 'CORE B',
};

const selectedOrder = {
  'benbrahim-2026-sumo-x-pypsa': 1,
  'yuan-2024-multiplex-gbo': 2,
  'zhang-2025-interdiction': 3,
};

const selectedCitations = selectedWorks
  .filter((work) => selectedFilters.some((filter) => filter.key === 'all' || filter.key === work.direction))
  .sort((a, b) => {
    const orderA = selectedOrder[a.slug] ?? 999;
    const orderB = selectedOrder[b.slug] ?? 999;
    if (orderA !== orderB) return orderA - orderB;
    return Number(b.year) - Number(a.year);
  })
  .map((work) => ({
    ...work,
    citation: work.citationOverride || formatChicagoCitation(work),
    categoryLabel: selectedCategoryLabels[work.direction] || work.direction,
    coreRanking: coreRankings[work.venue] || null,
    links: [
      { label: 'paper', href: work.href },
      ...(work.related?.filter((r) => /code|repo/i.test(r.label)).slice(0, 1).map((r) => ({ label: 'code', href: r.href })) ?? []),
      ...(work.doi ? [{ label: 'doi', href: work.doi }] : []),
    ]
  }));

