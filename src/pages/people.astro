---
import Layout from '../layouts/Layout.astro';

const currentPhD = ['Marouane Benbrahim','Tamanna Rashme','Josh Waldbieser','Xinyuan Chen','Zijian Zhang','Jiashan Wu',"Rocker D'Antonio",'Shaowen Wang'];
const currentMS = [];
const graduated = [
  { name: 'Zonghan Zhang', role: 'Ph.D.' },
  { name: 'Amin George', role: 'Ph.D.' },
  { name: 'Sai Harika Gade', role: 'M.S.' },
  { name: 'Pavan Dharma Adapa', role: 'M.S.' },
  { name: 'Matthew Rester', role: 'M.S.' },
  { name: 'Henry Smith', role: 'M.S.' },
  { name: 'Samuel Prabhakar', role: 'M.S.' },
  { name: 'Rajeev Jogi', role: 'M.S.' },
  { name: 'Piero Bracamonte', role: 'M.S.' },
  { name: 'Suman Adhikari', role: 'M.S.' },
  { name: 'Ramyasri Veerapaneni', role: 'M.S.' },
  { name: 'Aymane Jouhari', role: 'M.S.' },
];
---
<Layout title="People | Zhiqian Chen">
  <main class="container">
    <nav class="top-nav" aria-label="Sections">
      <a href="/">Home</a>
      <a href="/research">Research</a>
      <a href="/grant">Grant</a>
      <a href="/people" aria-current="page">People</a>
      <a href="/teach">Teach</a>
      <a href="https://scholar.google.com/scholar?q=Zhiqian+Chen" target="_blank" rel="noopener">Paper <i class="ai ai-google-scholar-square ai-sm nav-ghost"></i> <i class="fas fa-arrow-up-right-from-square nav-ghost"></i></a>
      <a href="https://substack.com/@zhiqianchen1" target="_blank" rel="noopener">Zhiqian's Note <svg class="nav-ghost nav-substack" viewBox="0 0 24 24" fill="currentColor" width="11" height="11" aria-hidden="true"><path d="M22.539 8.242H1.46V5.406h21.08v2.836zM1.46 10.812V24L12 18.11 22.54 24V10.812H1.46zM22.54 0H1.46v2.836h21.08V0z"/></svg> <i class="fas fa-arrow-up-right-from-square nav-ghost"></i></a>
    </nav>
    <section class="hero">
      <h1>People</h1>
    </section>
    <section class="section">
      <h2>Current Advisees</h2>
      <ul class="people-list">
        {currentPhD.map((name) => (<li><span class="name">{name}</span><span class="role">Ph.D.</span></li>))}
        {currentMS.map((name) => (<li><span class="name">{name}</span><span class="role">M.S.</span></li>))}
      </ul>
    </section>
    <section class="section">
      <h2>Recent Alumni</h2>
      <ul class="people-list alumni">
        {graduated.map((p) => (<li><span class="name">{p.name}</span><span class="role">{p.role}</span></li>))}
      </ul>
    </section>
  </main>
</Layout>
<style>
  :root { --accent:#2563eb; --ink:#0f172a; --muted:#475569; }
  .container { max-width: min(95vw, 1600px); margin: 0 auto; padding: 20px; box-sizing: border-box; }
  .top-nav { margin-bottom: 14px; padding: 10px 0 14px; display:flex; flex-wrap:wrap; gap:8px; align-items:center; background:transparent; border:none; border-bottom:none; border-radius:0; box-shadow:none; }
  .top-nav a { text-decoration:none; color:var(--ink); font-family:'Montserrat',sans-serif; font-size:.9rem; padding:7px 10px; border-radius:999px; background:transparent; }
  .top-nav a:hover { background:#dbeafe; color:var(--accent); }
  .top-nav a[aria-current="page"] { background: #eef2ff; color: var(--accent); box-shadow: inset 0 1px 2px rgba(15,23,42,0.10), inset 0 -1px 2px rgba(37,99,235,0.08); }
  .nav-ghost { font-size:.78rem; margin-left:4px; opacity:.85; }
  .nav-substack { vertical-align: -1px; opacity: .85; }
  .hero { margin: 10px 0 28px; }
  .hero h1 { font-family:'Montserrat',sans-serif; font-size:2rem; margin:0 0 8px; }
  .hero p { margin:0; color:var(--muted); max-width:780px; }
  .section { padding-top:18px; margin-top:26px; border-top:none; }
  .section h2 { font-family:'Montserrat',sans-serif; font-size:1.1rem; margin:0 0 14px; }
  .people-list { list-style:none; padding:0; margin:0; display:grid; grid-template-columns: repeat(3, minmax(0,1fr)); gap:4px 24px; }
  .people-list li { display:flex; align-items:baseline; justify-content:space-between; gap:10px; padding:4px 0; border-bottom:1px solid rgba(148,163,184,.14); }
  .people-list .name { color:var(--ink); font-size:.95rem; }
  .people-list .role { color:var(--muted); font-size:.78rem; letter-spacing:.04em; text-transform:uppercase; }
  .people-list.alumni li { border-bottom-style:dotted; }
  @media (max-width: 900px) { .people-list { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 600px) { .people-list { grid-template-columns: 1fr; } }
</style>
