---
import Layout from '../layouts/Layout.astro';

const updates = [
  { type: 'paper', date: '01/2026', text: 'Our co-simulation of power network and transportation network has been accepted by <strong>WebConf (WWW) 2026</strong>.' },
  { type: 'tutorial', date: '01/2026', text: 'Will give a tutorial on uncertainty quantification on graph dynamics at <strong>WSDM 2026</strong>.' },
  { type: 'honor', date: '11/2025', text: 'Recognized as a <strong>Research Fellow</strong> at the Social Science Research Center, Mississippi State University.' },
  { type: 'grant', date: '08/2025', text: 'Received <strong>Turing AI Gift</strong> funding for LLM research.' },
  { type: 'grant', date: '06/2025', text: 'Received <strong>NSF CAREER Award</strong> for unification and interactions across heterogeneous graph dynamics.' },
  { type: 'award', date: '05/2025', text: 'Received <strong>Ottilie Schillig Teaching Award</strong> (AI teaching gamification with Lego Edu Kit).' },
  { type: 'tutorial', date: '02/2025', text: 'Tutorial: Uncertainty Quantification for Dynamical Networks (<strong>WSDM 2025</strong>).' },
  { type: 'tutorial', date: '10/2024', text: 'Tutorial series on unifying spectral and spatial GNNs (<strong>CIKM 2024</strong> / <strong>SIAM MDS 2024</strong>).' },
  { type: 'grant', date: '08/2024', text: 'Received <strong>NSF CNS/MSI</strong> fund (co-PI) for speech recognition in English and Spanish with graph learning + LLMs.' },
  { type: 'grant', date: '07/2024', text: 'Received <strong>NSF CNS/CIRC</strong> fund (PI) to develop research infrastructure for graph dynamics.' },
  { type: 'paper', date: '07/2024', text: '1 paper accepted at <strong>IJCAI 2024</strong> and 2 papers accepted at <strong>EMBC 2024</strong>.' },
  { type: 'grant', date: '06/2024', text: 'Started spatial epidemiology of animal disease collaboration under <strong>USDA-ARS</strong> funded project.' },
  { type: 'grant', date: '04/2024', text: 'Received <strong>NSF EDU/ITEST</strong> fund (co-PI) for AI education research.' },
  { type: 'grant', date: '01/2024', text: 'Received <strong>NSF IIS/III REU Supplement</strong> (PI) for undergraduate research.' },
  { type: 'paper', date: '12/2023', text: 'Two papers accepted by <strong>AAAI 2024</strong> on Graph Bayesian Optimization.' },
  { type: 'grant', date: '12/2023', text: 'Launched cross-disciplinary <strong>Graph AI Working Group</strong> (supported by BCoE).' },
  { type: 'grant', date: '08/2023', text: 'Received support from <strong>USDA-ARS</strong> funded project (co-PI) on disease genetics.' },
  { type: 'paper', date: '12/2022', text: 'Paper accepted by <strong>SIAM SDM 2023</strong>: higher-order decomposition for influence maximization.' },
  { type: 'grant', date: '04/2022', text: 'Received <strong>NSF IIS/III</strong> fund (PI) for interpretable graph dynamics.' },
  { type: 'tutorial', date: '05/2021', text: 'Tutorial on spreading models for epidemics at <strong>SDM 2021</strong> (GNN/RNN/SIR/PDE).' },
  { type: 'award', date: '09/2020', text: '<strong>Best Paper Award</strong> at <strong>ACM SIGSPATIAL 2020</strong>.' },
  { type: 'paper', date: '12/2019', text: '<strong>Nature Communications</strong> paper selected in Top 50 Chemistry & Materials Sciences articles.' },
];

const openProblems = [
  'How can we build a general theory for graph dynamics across heterogeneous networks?',
  'When and where do uncertainty, interaction, and intervention become identifiable in coupled systems?',
  'How should we model LLMs and neural architectures as graph-structured dynamic systems?',
  'What does reliable software/hardware co-design look like for modern AI inference and control?',
];

const githubProjects = [
  'XGraph-Team/Spectral-Graph-Survey',
  'XGraph-Team/Fusion-GAN',
  'XGraph-Team/XFlow',
  'XGraph-Team/SumoXPypsa',
];

const githubCards = await Promise.all(
  githubProjects.map(async (slug) => {
    const url = `https://api.github.com/repos/${slug}`;
    try {
      const res = await fetch(url, { headers: { 'User-Agent': 'imczq-astro' } });
      if (!res.ok) throw new Error(`GitHub ${res.status}`);
      const repo = await res.json();
      return {
        slug,
        name: repo.name,
        owner: repo.owner?.login ?? 'XGraph-Team',
        desc: (({
          'Spectral-Graph-Survey': 'Survey-driven entry point to spectral graph theory, graph signals, and modern graph learning.',
          'Fusion-GAN': 'Music generation project on genre fusion with adversarial dual learning.',
          'XFlow': 'Python library for graph flow simulation, diffusion, and network dynamics experiments.',
          'SumoXPypsa': 'Coupled transportation-power simulation stack behind the WWW 2026 line of work.',
        })[repo.name]) || repo.description || 'Repository details coming soon.',
        href: repo.html_url,
        stars: repo.stargazers_count ?? 0,
        language: repo.language || 'Mixed',
        updated: '',
        customDesc: ({
          'Spectral-Graph-Survey': 'Survey-driven entry point to spectral graph theory, graph signals, and modern graph learning.',
          'Fusion-GAN': 'Music generation project on genre fusion with adversarial dual learning.',
          'XFlow': 'Python library for graph flow simulation, diffusion, and network dynamics experiments.',
          'SumoXPypsa': 'Coupled transportation-power simulation stack behind the WWW 2026 line of work.',
        })[repo.name] || '',
      };
    } catch {
      const [owner, name] = slug.split('/');
      return {
        slug,
        name,
        owner,
        desc: 'Repository details temporarily unavailable.',
        href: `https://github.com/${slug}`,
        stars: null,
        language: '',
        updated: '',
      };
    }
  })
);

const ghostEntries = [
  { title: 'Tech Note #1', meta: 'Placeholder', desc: 'Short technical writing will land here.' },
  { title: 'Research Note #1', meta: 'Placeholder', desc: 'Working notes, paper thoughts, and prototypes.' },
  { title: 'Build Log #1', meta: 'Placeholder', desc: 'Small writeups on tools, systems, and experiments.' },
];

const workGallery = [
  { src: 'https://imczq.com/media/research_statement_hucb80f2447a0a6a816bf6ea6adae9c7ee_371656_1200x1200_fit_q75_h2_lanczos_3.webp', alt: 'Research statement visual' },
  { src: 'https://imczq.com/project/unifying/featured_hu352832247ca9de48ec6cd5688ca312ae_768239_540x0_resize_q75_h2_lanczos.webp', alt: 'Unified framework for graphs' },
  { src: 'https://imczq.com/project/gbo/featured_hud696c5486f3d729ebf5ee1ceaffacccd_128059_540x0_resize_q75_h2_lanczos_3.webp', alt: 'Graph Bayesian Optimization' },
];

const selectedDirections = [
  {
    title: 'Spectral graph theory',
    desc: 'Using spectral perspectives to understand graph structure, operators, and learning behavior.',
  },
  {
    title: 'UQ for graph dynamics',
    desc: 'Studying uncertainty quantification, inference, and intervention in graph-driven dynamical systems.',
  },
  {
    title: 'Cross-network graph dynamics',
    desc: 'Understanding how heterogeneous networks interact, couple, and evolve together over time.',
  },
  {
    title: 'General theory for graph dynamics',
    desc: 'Searching for broader principles that unify dynamics, interaction, and controllability on graphs.',
  },
];

const selectedWorks = [
  { name: 'Unified GNN framework', status: 'Direction', venue: 'ACM CSUR 2023', output: 'Survey and tutorial-building effort toward unifying spectral and spatial graph learning.', image: 'https://imczq.com/project/unifying/featured_hu352832247ca9de48ec6cd5688ca312ae_768239_540x0_resize_q75_h2_lanczos.webp' },
  { name: 'Influence on graphs', status: 'Project', venue: 'AAAI 2024', output: 'Graph Bayesian Optimization, source localization, and influence maximization for dynamic and multiplex networks.', image: 'https://imczq.com/project/gbo/featured_hud696c5486f3d729ebf5ee1ceaffacccd_128059_540x0_resize_q75_h2_lanczos_3.webp' },
  { name: 'Spatiotemporal and urban forecasting', status: 'Awarded', venue: 'SIGSPATIAL 2020', output: 'Graph-temporal forecasting for traffic and mobility, including award-winning work on urban intelligence.', image: 'https://imczq.com/project/20_kalman_gis/featured_hu6d4d4db39f7ac31cad16d8b437bab632_85075_540x0_resize_q75_h2_lanczos_3.webp' },
  { name: 'Materials and scientific discovery', status: 'Science', venue: 'Nature Communications 2019', output: 'Graph/ML-enabled discovery for solid-state lithium-ion conductors and related science-facing systems.', image: 'https://imczq.com/project/17_fusiongan_icdm/featured_hu79af7702fdd7ef1f1d4d79a2bd7a81f7_90601_540x0_resize_q75_h2_lanczos_3.webp' },
  { name: 'Interdisciplinary AI infrastructure', status: 'Systems', venue: 'WWW 2026', output: 'Cross-domain graph infrastructure spanning epidemiology, agriculture, transportation, and engineering.', image: 'https://imczq.com/project/23_sim_sdm/featured_hu47ed903882ca2a20b0bbd31dfd70f9ab_135606_540x0_resize_q75_h2_lanczos_3.webp' },
];
---

<Layout title="Zhiqian Chen | Homepage Prototype">
  <main class="container" id="top">
      <nav class="top-nav card" aria-label="Sections">
        <a href="/" aria-current="page">Home</a>
        <a href="/research">Research</a>
        <a href="/people">People</a>
        <a href="/teach">Teach</a>
        <a href="https://zhiqian.ai" target="_blank" rel="noopener">Zhiqian.ai <i class="fas fa-ghost nav-ghost"></i></a>
      </nav>
    <section class="grid-3">
      <aside class="left-col">
        <article class="card module profile">
          <img class="avatar" src="https://imczq.com/authors/admin/avatar_huff586cc3096ffa7a7257f5a661abe783_130497_270x270_fill_q75_lanczos_center.jpg" alt="Zhiqian Chen" />
          <h1 class="name-en">Chen, Zhiqian</h1>
          <p class="name-zh">陈枳扦
            <span class="name-tip" tabindex="0" aria-label="Name meaning note">?
              <span class="tip-pop">物理含义：根据五行八卦算的</span>
            </span>
          </p>
          <p class="role">Assistant Professor · Mississippi State University</p>
          <p class="bio">I am an Assistant Professor of Computer Science &amp; Engineering at Mississippi State University, focusing on graph-structured intelligence for dynamic, uncertain, and knowledge-rich systems (see <a href="#research">details of my research interests</a>). I obtained my Ph.D. at Virginia Tech in 2020, under the supervision of Dr. Chang-Tien Lu. For students interested in me, check <a href="#connect-form">ways to work with me</a>. If interested in my courses, please check the <a href="#teach">course syllabi</a>.</p>

          <div class="icons" aria-label="social links">
            <a href="https://imczq.com/cv.pdf" title="CV"><i class="ai ai-cv"></i></a>
            <a href="https://scholar.google.com/citations?hl=en&user=NC3-O6UAAAAJ" title="Google Scholar"><i class="ai ai-google-scholar"></i></a>
            <a href="https://github.com/aquastar" title="GitHub"><i class="fab fa-github"></i></a>
            <a href="https://twitter.com/imczq" title="X/Twitter"><i class="fab fa-square-x-twitter"></i></a>
            <a href="https://www.linkedin.com/in/zhiqian-chen-ai/" title="LinkedIn"><i class="fab fa-linkedin"></i></a>
            <a href="https://www.zhihu.com/people/aquastar" title="Zhihu"><i class="fab fa-zhihu"></i></a>
            <a href="https://www.xiaohongshu.com/user/profile/64769efb000000001c029738" title="Xiaohongshu"><i class="fas fa-book"></i></a>
            <a href="https://orcid.org/0000-0003-4112-9647" title="ORCID"><i class="fab fa-orcid"></i></a>
            <a href="mailto:zchen@cse.msstate.edu" title="Email"><i class="fas fa-envelope"></i></a>
          </div>
        </article>

        <article class="card module">
          <div class="module-head">
            <h2>Recent Updates</h2>
          </div>
          <ul class="updates">
            {updates.map((u) => (
              <li>
                <span class={`tag ${u.type}`}>{u.type}</span>
                <span class="date-strong">{u.date}</span><span class="meta-inline" set:html={u.text}></span>
              </li>
            ))}
          </ul>
        </article>
      </aside>

      <section class="center-col">
        <article class="card module rich hero-module" id="research">
                    <h2>Research Statement</h2>
          <p class="lead">I am interested in graph-structured intelligence for dynamic, uncertain, and knowledge-rich systems.</p>
          <div class="direction-visual">
            <img src={workGallery[0].src} alt={workGallery[0].alt} />
          </div>
          <div class="statement-copy">
            <p>My recent work spans <strong>spectral graph theory</strong>, <strong>uncertainty quantification for graph dynamics</strong>, <strong>cross-network graph dynamics</strong>, and the search for a <strong>general theory for graph dynamics</strong>. Across these directions, I care about models that are predictive, interpretable, and theoretically grounded.</p>
            <p>I have worked on projects in transportation, spatial epidemiology, social systems, circuits, and AI systems, and I often collaborate across disciplines to connect graph-based methods with real-world dynamic processes.</p>
          </div>
        </article>

        <article class="card module rich" id="selected-work">
                    <h2>Selected Directions + Works</h2>
          <div class="work-montage">
            {selectedWorks.map((p) => (
              <article class="montage-card">
                <img src={p.image} alt={p.name} />
                <div class="montage-overlay">
                  <div class="work-tags">
                    <span class="badge venue">{p.venue}</span>
                  </div>
                  <h3>{p.name}</h3>
                  <p>{p.output}</p>
                </div>
              </article>
            ))}
          </div>
        </article>

        <article class="card module rich" id="people">
          <h2>People</h2>
          <p>I work with students and collaborators from CSE, data science, and interdisciplinary application domains.</p>
          <p>If you are interested in graph dynamics, UQ, spectral methods, LLM/Transformers, or AI education, please reach out through the collaboration form.</p>
        </article>
      </section>

      <aside class="right-col">
        <article class="card module accent open-problems-card" id="open-problems">
                    <h2>Open Problems</h2>
          <div class="open-problems-quote">
            <span class="quote-mark">“</span>
            <ul class="selected-list compact-list">
              {openProblems.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        </article>

        <article class="card module" id="github-projects">
                    <h2>Tutorial-related Repos</h2>
          <div class="stack dense">
            {githubCards.map((repo) => (
              <a class="mini-card repo-card" href={repo.href} target="_blank" rel="noopener">
                <div class="row repo-top">
                  <div class="repo-title-wrap">
                    <h3>{repo.name}</h3>
                  </div>
                  <i class="fab fa-github repo-icon"></i>
                </div>
                <p>{repo.desc}</p>
                <div class="repo-meta">
                  <span>@{repo.owner}</span>
                  {repo.language && <span>{repo.language}</span>}
                  {repo.stars !== null && <span>★ {repo.stars}</span>}
                </div>
              </a>
            ))}
          </div>
        </article>

        <article class="card module ghost-card" id="ghost-entries">
                    <h2>Tech Notes</h2>
          <div class="stack dense">
            {ghostEntries.map((entry) => (
              <div class="mini-card note-card placeholder">
                <div class="row"><h3>{entry.title}</h3><span class="repo-pill muted">{entry.meta}</span></div>
                <p>{entry.desc}</p>
              </div>
            ))}
          </div>
        </article>

        <article class="card module" id="connect-form">
          <h2>Quick message to me</h2>
          <p>Send me a short note directly.</p>
          <form id="collab-form" class="form">
            <input id="f-email" name="email" type="email" placeholder="Email" required />
            <textarea id="f-message" name="message" placeholder="Message" rows="4" required></textarea>
            <button class="btn full" type="submit" id="form-submit-btn">Send Inquiry</button>
          </form>
          <p id="form-status" class="small"></p>
        </article>

        <article class="card module">
          <h2>Like this page</h2>
          <p>Anonymous likes only.</p>
          <button id="like-btn" class="btn full like-btn" type="button">
            <span id="like-emoji">👍</span>
            <span id="like-label">Like</span>
            <span id="like-count-badge" class="like-badge" style="display:none"></span>
          </button>
          <p id="like-status" class="small"></p>
        </article>
      </aside>
    </section>
  </main>

  <script>
    // Like button
    const likeBtn = document.getElementById('like-btn') as HTMLButtonElement | null;
    const likeEmoji = document.getElementById('like-emoji');
    const likeLabel = document.getElementById('like-label');
    const likeStatus = document.getElementById('like-status');
    const likedKey = 'imczq_liked';

    function setLiked() {
      if (!likeBtn) return;
      likeBtn.disabled = true;
      likeBtn.classList.add('liked');
      if (likeEmoji) likeEmoji.textContent = '❤️';
      if (likeLabel) likeLabel.textContent = 'Liked!';
      if (likeStatus) likeStatus.textContent = 'Thanks for your support!';
    }

    if (likeBtn && localStorage.getItem(likedKey) === '1') {
      setLiked();
    }

    if (likeBtn) {
      likeBtn.addEventListener('click', async () => {
        if (likeBtn.disabled) return;
        // Immediate visual pop
        likeBtn.classList.remove('like-pop');
        void likeBtn.offsetWidth; // reflow to restart animation
        likeBtn.classList.add('like-pop');
        likeBtn.disabled = true;

        try {
          const res = await fetch('/api/like', { method: 'POST' });
          if (res.ok) {
            localStorage.setItem(likedKey, '1');
            setLiked();
          } else if (res.status === 429) {
            likeBtn.disabled = false;
            if (likeStatus) likeStatus.textContent = 'Already liked recently.';
          } else {
            likeBtn.disabled = false;
            if (likeStatus) likeStatus.textContent = 'Failed, try again.';
          }
        } catch {
          likeBtn.disabled = false;
          if (likeStatus) likeStatus.textContent = 'Network error.';
        }
      });
    }

    // Inquiry form
    const form = document.getElementById('collab-form') as HTMLFormElement | null;
    const formStatus = document.getElementById('form-status');
    const submitBtn = document.getElementById('form-submit-btn') as HTMLButtonElement | null;

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!submitBtn || !formStatus) return;
      submitBtn.disabled = true;
      formStatus.textContent = 'Sending...';

      const payload = {
        email: (document.getElementById('f-email') as HTMLInputElement).value,
        message: (document.getElementById('f-message') as HTMLTextAreaElement).value,
      };

      try {
        const res = await fetch('/api/inquiry', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        if (res.ok) {
          formStatus.textContent = '✓ Sent! I will get back to you soon.';
          form.reset();
        } else {
          formStatus.textContent = 'Failed to send. Please try again.';
          submitBtn.disabled = false;
        }
      } catch {
        formStatus.textContent = 'Network error. Please try again.';
        submitBtn.disabled = false;
      }
    });
  </script>
</Layout>

<style>
  .container { max-width: 1800px; margin: 0 auto; padding: 20px; }
  .card { background: rgba(255,255,255,0.92); border: 1px solid rgba(148,163,184,0.12); border-radius: 18px; box-shadow: 0 10px 30px rgba(15,23,42,0.06); backdrop-filter: blur(10px); }
    .top-nav { margin-bottom: 14px; padding: 10px 0 14px; display: flex; flex-wrap: wrap; gap: 8px; align-items: center; background: transparent; border: none; border-bottom: 1px solid rgba(148,163,184,0.22); border-radius: 0; box-shadow: none; }
  .top-nav a { text-decoration: none; color: var(--ink); font-family: 'Montserrat', sans-serif; font-size: 0.9rem; padding: 7px 10px; border-radius: 999px; background: transparent; }
  .top-nav a:hover { background: var(--accent-soft); color: var(--accent); }
  .top-nav a[aria-current="page"] { background: #eef2ff; color: var(--accent); box-shadow: inset 0 1px 2px rgba(15,23,42,0.10), inset 0 -1px 2px rgba(37,99,235,0.08); }
  .nav-ghost { font-size: 0.78rem; margin-left: 4px; opacity: .85; }
  .grid-3 { display: grid; grid-template-columns: 0.92fr 2.28fr 0.88fr; gap: 28px; align-items: start; }
  .module { padding: 16px; margin-bottom: 14px; }
  .module-head { display: flex; align-items: center; justify-content: space-between; gap: 10px; }
  .small { font-size: 0.8rem; color: #475569; }
  :root { --accent: #2563eb; --accent-soft: #dbeafe; --ink: #0f172a; --muted: #475569; --page: #ffffff; }
  body { background: var(--page); }
  .module-kicker { display:inline-block; margin-bottom:8px; font-size:0.72rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:var(--accent); background:var(--accent-soft); padding:4px 8px; border-radius:999px; }
  .hero-module { background: #ffffff; }
  .accent { background: #ffffff; }
  .direction { background: #ffffff; border: 1px solid rgba(37,99,235,0.10); }
  .repo-card, .note-card { text-decoration:none; color:inherit; transition: transform .15s ease, box-shadow .15s ease; }
  .repo-card:hover { transform: translateY(-2px); box-shadow: 0 10px 24px rgba(37,99,235,0.08); }
  .repo-pill { font-size:0.72rem; color:#2563eb; background:#dbeafe; padding:3px 8px; border-radius:999px; white-space:nowrap; }
  .repo-pill.muted { color:#7c3aed; background:#ede9fe; }
  .compact-list { padding-left: 18px; display:grid; gap:10px; }
  .compact-list li { color:#1e293b; }
  .ghost-card .placeholder { background: #ffffff; }


  .profile { text-align: center; background: #fff; }
  .avatar { width: 100%; height: auto; aspect-ratio: 1 / 1; border-radius: 16px; object-fit: cover; border: none; }
  h1 { font-family: 'Montserrat', sans-serif; font-size: 1.9rem; margin: 12px 0 4px; }
  .name-en { font-size: 2rem; letter-spacing: 0.01em; }
  .name-zh { margin: 2px 0 0; font-size: 1rem; color: #334155; display: inline-flex; align-items: center; gap: 6px; }
  .name-tip { position: relative; display: inline-flex; align-items: center; justify-content: center; width: 16px; height: 16px; border-radius: 999px; background: #cbd5e1; color: #0f172a; font-size: 0.72rem; line-height: 1; cursor: help; }
  .tip-pop { position: absolute; left: 22px; top: 50%; transform: translateY(-50%); white-space: nowrap; background: #0f172a; color: #fff; padding: 4px 8px; border-radius: 6px; font-size: 0.72rem; opacity: 0; pointer-events: none; transition: opacity .15s ease; }
  .name-tip:hover .tip-pop, .name-tip:focus .tip-pop { opacity: 1; }
  .role { margin: 0; color: #334155; font-size: 0.92rem; }
  .bio { text-align: left; color: #334155; font-size: 0.92rem; margin-top: 10px; }

  .icons { display: flex; flex-wrap: wrap; justify-content: center; gap: 10px; margin-top: 14px; }
  .icons a { color: #334155; text-decoration: none; transition: color .15s ease, transform .15s ease; }
  .icons a:hover { color: #0f172a; transform: translateY(-1px); }
  .icons i { font-size: 1.95rem; }

  h2 { font-family: 'Montserrat', sans-serif; font-size: 1.2rem; margin: 0 0 12px; }
  h3 { font-family: 'Montserrat', sans-serif; font-size: 1rem; margin: 0 0 6px; }
  ul { margin: 0; padding-left: 18px; color: #334155; }
  li { margin-bottom: 6px; }
  .updates { list-style: none; padding-left: 0; display: grid; gap: 8px; }
  .updates li { display: block; line-height: 1.35; }
  .meta-inline { font-size: 0.88rem; color: #1e293b; line-height: 1.35; white-space: normal; overflow: visible; text-overflow: clip; }
  .date-strong { font-size: 0.82rem; font-weight: 700; color: #0f172a; white-space: nowrap; margin: 0 8px 0 6px; }
  .tag { font-size: 0.68rem; text-transform: uppercase; border-radius: 999px; padding: 2px 7px; font-weight: 700; }
  .tag.grant { background: #dcfce7; color: #166534; }
