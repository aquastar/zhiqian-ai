---
import Layout from '../layouts/Layout.astro';

const updates = [
  { type: 'paper', date: '01/2026', text: 'Our co-simulation of power network and transportation network has been accepted by <strong>WebConf (WWW) 2026</strong>.' },
  { type: 'tutorial', date: '01/2026', text: 'Will give a tutorial on uncertainty quantification on graph dynamics at <strong>WSDM 2026</strong>.' },
  { type: 'honor', date: '11/2025', text: 'Recognized as a <strong>Research Fellow</strong> at the Social Science Research Center, Mississippi State University.' },
  { type: 'grant', date: '08/2025', text: 'Received <strong>Turing AI Gift</strong> funding for LLM research.' },
  { type: 'grant', date: '06/2025', text: 'Received <strong>NSF CAREER Award</strong> for unification and interactions across heterogeneous graph dynamics.' },
  { type: 'award', date: '05/2025', text: 'Received <strong>Ottilie Schillig Teaching Award</strong> (AI teaching gamification with Lego Edu Kit).' },
  { type: 'tutorial', date: '02/2025', text: 'Tutorial: Uncertainty Quantification for Dynamical Networks (<strong>WSDM 2025</strong>).' },
  { type: 'tutorial', date: '10/2024', text: 'Tutorial series on unifying spectral and spatial GNNs (<strong>CIKM 2024</strong> / <strong>SIAM MDS 2024</strong>).' },
  { type: 'grant', date: '08/2024', text: 'Received <strong>NSF CNS/MSI</strong> fund (co-PI) for speech recognition in English and Spanish with graph learning + LLMs.' },
  { type: 'grant', date: '07/2024', text: 'Received <strong>NSF CNS/CIRC</strong> fund (PI) to develop research infrastructure for graph dynamics.' },
  { type: 'paper', date: '07/2024', text: '1 paper accepted at <strong>IJCAI 2024</strong> and 2 papers accepted at <strong>EMBC 2024</strong>.' },
  { type: 'grant', date: '06/2024', text: 'Started spatial epidemiology of animal disease collaboration under <strong>USDA-ARS</strong> funded project.' },
  { type: 'grant', date: '04/2024', text: 'Received <strong>NSF EDU/ITEST</strong> fund (co-PI) for AI education research.' },
  { type: 'grant', date: '01/2024', text: 'Received <strong>NSF IIS/III REU Supplement</strong> (PI) for undergraduate research.' },
  { type: 'paper', date: '12/2023', text: 'Two papers accepted by <strong>AAAI 2024</strong> on Graph Bayesian Optimization.' },
  { type: 'grant', date: '12/2023', text: 'Launched cross-disciplinary <strong>Graph AI Working Group</strong> (supported by BCoE).' },
  { type: 'grant', date: '08/2023', text: 'Received support from <strong>USDA-ARS</strong> funded project (co-PI) on disease genetics.' },
  { type: 'paper', date: '12/2022', text: 'Paper accepted by <strong>SIAM SDM 2023</strong>: higher-order decomposition for influence maximization.' },
  { type: 'grant', date: '04/2022', text: 'Received <strong>NSF IIS/III</strong> fund (PI) for interpretable graph dynamics.' },
  { type: 'tutorial', date: '05/2021', text: 'Tutorial on spreading models for epidemics at <strong>SDM 2021</strong> (GNN/RNN/SIR/PDE).' },
  { type: 'award', date: '09/2020', text: '<strong>Best Paper Award</strong> at <strong>ACM SIGSPATIAL 2020</strong>.' },
  { type: 'paper', date: '12/2019', text: '<strong>Nature Communications</strong> paper selected in Top 50 Chemistry & Materials Sciences articles.' },
];

const openProblems = [
  'How can we build a general theory for graph dynamics across heterogeneous networks?',
  'When and where do uncertainty, interaction, and intervention become identifiable in coupled systems?',
  'How should we model LLMs and neural architectures as graph-structured dynamic systems?',
  'What does reliable software/hardware co-design look like for modern AI inference and control?',
];

const githubCards = [
  { name: 'Spectral Graph', owner: 'XGraph-Team', repo: 'Spectral-Graph-Survey', stars: 175, language: 'Python', href: 'https://github.com/XGraph-Team/Spectral-Graph-Survey', starHref: 'https://github.com/XGraph-Team/Spectral-Graph-Survey/stargazers', desc: 'Survey-driven entry point to spectral graph theory, graph signals, and modern graph learning.' },
  { name: 'Fusion GAN', owner: 'XGraph-Team', repo: 'Fusion-GAN', stars: 19, language: 'Python', href: 'https://github.com/XGraph-Team/Fusion-GAN', starHref: 'https://github.com/XGraph-Team/Fusion-GAN/stargazers', desc: 'Music generation project on genre fusion with adversarial dual learning.' },
  { name: 'XFlow', owner: 'XGraph-Team', repo: 'XFlow', stars: 147, language: 'Python', href: 'https://github.com/XGraph-Team/XFlow', starHref: 'https://github.com/XGraph-Team/XFlow/stargazers', desc: 'Python library for graph flow simulation, diffusion, and network dynamics experiments.' },
  { name: 'SumoXPypsa', owner: 'XGraph-Team', repo: 'SumoXPypsa', stars: 2, language: 'Python', href: 'https://github.com/XGraph-Team/SumoXPypsa', starHref: 'https://github.com/XGraph-Team/SumoXPypsa/stargazers', desc: 'Coupled transportation-power simulation stack behind the WWW 2026 line of work.' }
];

const ghostEntries = [
  { title: 'Tech Note #1', meta: 'Placeholder', desc: 'Short technical writing will land here.' },
  { title: 'Research Note #1', meta: 'Placeholder', desc: 'Working notes, paper thoughts, and prototypes.' },
  { title: 'Build Log #1', meta: 'Placeholder', desc: 'Small writeups on tools, systems, and experiments.' },
];

const selectedWorks = [
  { name: 'Unified GNN framework', venue: 'ACM CSUR 2023', output: 'Survey and tutorial-building effort toward unifying spectral and spatial graph learning.', detail: 'Problem: spectral and spatial GNNs are often treated as separate camps. Contribution: I developed a unifying view that connects these perspectives and turned it into a survey/tutorial line. Why it matters: it gives researchers and students a cleaner conceptual map for graph learning.', keywords: 'spectral · spatial · GNN theory', href: 'https://github.com/XGraph-Team/Spectral-Graph-Survey', starHref: 'https://github.com/XGraph-Team/Spectral-Graph-Survey/stargazers', image: 'https://imczq.com/project/unifying/featured_hu352832247ca9de48ec6cd5688ca312ae_768239_540x0_resize_q75_h2_lanczos.webp' },
  { name: 'Influence on graphs', venue: 'AAAI 2024', output: 'Graph Bayesian Optimization, source localization, and influence maximization for dynamic and multiplex networks.', detail: 'Problem: influence and diffusion decisions on graphs are combinatorial and uncertain. Contribution: I used Bayesian optimization and graph structure to localize sources and search efficiently over intervention choices. Why it matters: this makes graph decision-making more sample-efficient and more actionable.', keywords: 'UQ · diffusion · optimization', href: 'https://imczq.com/project/gbo/', image: 'https://imczq.com/project/gbo/featured_hud696c5486f3d729ebf5ee1ceaffacccd_128059_540x0_resize_q75_h2_lanczos_3.webp' },
  { name: 'Spatiotemporal and urban forecasting', venue: 'SIGSPATIAL 2020', output: 'Graph-temporal forecasting for traffic and mobility, including award-winning work on urban intelligence.', detail: 'Problem: urban systems evolve over both space and time, and purely local models miss network effects. Contribution: I combined graph structure with temporal filtering for traffic and mobility forecasting. Why it matters: this line connects theory to real infrastructure and practical urban prediction.', keywords: 'traffic · mobility · forecasting', href: 'https://imczq.com/project/20_kalman_gis/', image: 'https://imczq.com/project/20_kalman_gis/featured_hu6d4d4db39f7ac31cad16d8b437bab632_85075_540x0_resize_q75_h2_lanczos_3.webp' },
  { name: 'Materials and scientific discovery', venue: 'Nature Communications 2019', output: 'Graph/ML-enabled discovery for solid-state lithium-ion conductors and related science-facing systems.', detail: 'Problem: scientific discovery pipelines need better representations for complex candidate structures. Contribution: I used graph-based modeling to help screen and understand promising materials. Why it matters: this shows graph intelligence can accelerate discovery beyond standard CS benchmarks.', keywords: 'materials · science AI · discovery', href: 'https://imczq.com/project/17_fusiongan_icdm/', image: 'https://imczq.com/project/17_fusiongan_icdm/featured_hu79af7702fdd7ef1f1d4d79a2bd7a81f7_90601_540x0_resize_q75_h2_lanczos_3.webp' },
  { name: 'Interdisciplinary AI infrastructure', venue: 'WWW 2026', output: 'Cross-domain graph infrastructure spanning epidemiology, agriculture, transportation, and engineering.', detail: 'Problem: real systems rarely live in a single network; they interact across domains. Contribution: I built cross-domain graph infrastructure linking epidemiology, agriculture, transportation, and engineering settings. Why it matters: this is the kind of systems foundation needed for broader graph dynamics research.', keywords: 'cross-network · infrastructure · simulation', href: 'https://imczq.com/project/23_sim_sdm/', image: 'https://imczq.com/project/23_sim_sdm/featured_hu47ed903882ca2a20b0bbd31dfd70f9ab_135606_540x0_resize_q75_h2_lanczos_3.webp' },
];
---

<Layout title="Zhiqian Chen">
  <main class="container" id="top">
    <nav class="top-nav" aria-label="Sections">
      <a href="/" aria-current="page">Home</a>
      <a href="/research">Research</a>
      <a href="/grant">Grant</a>
      <a href="/people">People</a>
      <a href="/teach">Teach</a>
      <a href="https://scholar.google.com/scholar?q=Zhiqian+Chen" target="_blank" rel="noopener">Paper <i class="ai ai-google-scholar-square ai-sm nav-ghost"></i> <i class="fas fa-arrow-up-right-from-square nav-ghost"></i></a>
      <a href="https://zhiqian.ai" target="_blank" rel="noopener">Zhiqian's Note <i class="fas fa-arrow-up-right-from-square nav-ghost"></i></a>
    </nav>

    <section class="grid-2">
      <aside class="left-col">
        <article class="card module profile">
          <img class="avatar" src="https://imczq.com/authors/admin/avatar_huff586cc3096ffa7a7257f5a661abe783_130497_270x270_fill_q75_lanczos_center.jpg" alt="Zhiqian Chen" />
          <h1 class="name-en">Chen, Zhiqian</h1>
          <p class="name-zh">陈枳扦
            <span class="name-tip" tabindex="0" aria-label="Name meaning note">?
              <span class="tip-pop">物理含义：根据五行八卦算的</span>
            </span>
          </p>
          <p class="role">Assistant Professor · Mississippi State University</p>
          <p class="bio">I am an Assistant Professor of Computer Science &amp; Engineering at Mississippi State University, focusing on graph-structured intelligence for dynamic, uncertain, and knowledge-rich systems (see <a href="/research">details of my research interests</a>). I obtained my Ph.D. at Virginia Tech in 2020, under the supervision of Dr. Chang-Tien Lu. For students interested in me, check <a href="#connect-form">ways to work with me</a>. If interested in my courses, please check the <a href="/teach">course syllabi</a>.</p>

          <div class="icons" aria-label="social links">
            <a href="https://imczq.com/cv.pdf" title="CV"><i class="ai ai-cv"></i></a>
            <a href="https://scholar.google.com/citations?hl=en&user=NC3-O6UAAAAJ" title="Google Scholar"><i class="ai ai-google-scholar"></i></a>
            <a href="https://github.com/aquastar" title="GitHub"><i class="fab fa-github"></i></a>
            <a href="https://twitter.com/imczq" title="X/Twitter"><i class="fab fa-square-x-twitter"></i></a>
            <a href="https://www.linkedin.com/in/zhiqian-chen-ai/" title="LinkedIn"><i class="fab fa-linkedin"></i></a>
            <a href="https://www.zhihu.com/people/aquastar" title="Zhihu"><i class="fab fa-zhihu"></i></a>
            <a href="https://www.xiaohongshu.com/user/profile/64769efb000000001c029738" title="Xiaohongshu"><i class="fas fa-book"></i></a>
            <a href="https://orcid.org/0000-0003-4112-9647" title="ORCID"><i class="fab fa-orcid"></i></a>
            <a href="mailto:zchen@cse.msstate.edu" title="Email"><i class="fas fa-envelope"></i></a>
          </div>
        </article>

        <article class="card module">
          <h2>Recent Updates</h2>
          <ul class="updates">
            {updates.map((u) => (
              <li>
                <span class={`tag ${u.type}`}>{u.type}</span>
                <span class="date-strong">{u.date}</span><span class="meta-inline" set:html={u.text}></span>
              </li>
            ))}
          </ul>
        </article>
      </aside>

      <section class="right-col-main">
        <article class="card module rich hero-module" id="research">
          <h2>Research Statement</h2>
          <p class="lead">I am interested in graph-structured intelligence for dynamic, uncertain, and knowledge-rich systems.</p>
          <div class="direction-visual">
            <img src="https://imczq.com/media/research_statement_hucb80f2447a0a6a816bf6ea6adae9c7ee_371656_1200x1200_fit_q75_h2_lanczos_3.webp" alt="Research statement visual" />
          </div>
          <div class="statement-copy">
            <p>My recent work spans <strong>spectral graph theory</strong>, <strong>uncertainty quantification for graph dynamics</strong>, <strong>cross-network graph dynamics</strong>, and the search for a <strong>general theory for graph dynamics</strong>. Across these directions, I care about models that are predictive, interpretable, and theoretically grounded.</p>
            <p>I have worked on projects in transportation, spatial epidemiology, social systems, circuits, and AI systems, and I often collaborate across disciplines to connect graph-based methods with real-world dynamic processes.</p>
          </div>
        </article>

        <article class="card module rich" id="selected-work">
          <h2>Selected</h2>
          <div class="work-grid" id="selected-grid">
            {selectedWorks.map((p, idx) => (
              <article class="work-card" data-expand-card data-index={idx} data-name={p.name} data-venue={p.venue} data-output={p.output} data-detail={p.detail} data-keywords={p.keywords} data-href={p.href} data-image={p.image}>
                <img src={p.image} alt={p.name} />
                <div class="work-copy">
                  <div class="work-tags"><span class="badge venue">{p.venue}</span></div>
                  <h3>{p.name}</h3>
                  <p>{p.output}</p>
                </div>
              </article>
            ))}
          </div>
          <div class="selected-detail-panel" id="selected-detail-panel" hidden>
            <div class="work-detail">
              <div class="work-detail-media">
                <img id="detail-image" src="" alt="" />
              </div>
              <div class="work-detail-copy">
                <div class="work-tags"><span class="badge venue" id="detail-venue"></span></div>
                <h3 id="detail-title"></h3>
                <p id="detail-text"></p>
                <div class="detail-meta">
                  <span class="detail-label">Focus</span>
                  <p class="work-keywords" id="detail-keywords"></p>
                </div>
                <div class="detail-actions">
                  <a class="detail-link" id="detail-link" href="#" target="_blank" rel="noopener">Open project</a>
                </div>
              </div>
            </div>
          </div>
        </article>


        <article class="card module" id="github-projects">
          <h2>Tutorial-related Repos</h2>
          <div class="stack dense four-cols">
            {githubCards.map((repo) => (
              <article class="mini-card repo-card" data-href={repo.href} tabindex="0" role="link">
                <div class="row repo-top">
                  <h3>{repo.name}</h3>
                  <i class="fab fa-github repo-icon"></i>
                </div>
                <p>{repo.desc}</p>
                <div class="repo-meta repo-badges">
                  <img src={`https://img.shields.io/badge/${encodeURIComponent(repo.owner)}-f8fafc.svg?style=flat-square&logo=github&logoColor=181717&labelColor=f8fafc&color=f8fafc`} alt={`owner ${repo.owner}`} />
                  <img src={`https://img.shields.io/badge/${encodeURIComponent(repo.language)}-f8fafc.svg?style=flat-square&logo=python&logoColor=3776AB&labelColor=f8fafc&color=f8fafc`} alt={`language ${repo.language}`} />
                  <iframe class="github-star-btn" src={`https://ghbtns.com/github-btn.html?user=${repo.owner}&repo=${repo.repo}&type=star&count=true&size=small`} title={`Star ${repo.name} on GitHub`} width="96" height="20"></iframe>
                </div>
              </article>
            ))}
          </div>
        </article>

        <article class="card module ghost-card" id="ghost-entries">
          <h2>Tech Notes</h2>
          <div class="stack dense four-cols">
            {ghostEntries.map((entry) => (
              <div class="mini-card note-card placeholder">
                <div class="row"><h3>{entry.title}</h3><span class="repo-pill muted">{entry.meta}</span></div>
                <p>{entry.desc}</p>
              </div>
            ))}
          </div>
        </article>
      </section>
  </main>

  <script>
    const selectedCards = Array.from(document.querySelectorAll('[data-expand-card]'));
    const detailPanel = document.getElementById('selected-detail-panel');
    const selectedGrid = document.getElementById('selected-grid');
    const detailImage = document.getElementById('detail-image');
    const detailVenue = document.getElementById('detail-venue');
    const detailTitle = document.getElementById('detail-title');
    const detailText = document.getElementById('detail-text');
    const detailKeywords = document.getElementById('detail-keywords');
    const detailLink = document.getElementById('detail-link');
    let closeTimer;

    function resetCards() {
      selectedCards.forEach((c) => c.classList.remove('is-expanded'));
      selectedGrid?.classList.remove('has-expanded');
    }

    function collapseDetail(animated = true) {
      window.clearTimeout(closeTimer);
      resetCards();
      if (detailPanel.hidden) return;
      if (!animated) {
        detailPanel.hidden = true;
        detailPanel.classList.remove('is-collapsing');
        return;
      }
      detailPanel.classList.remove('is-collapsing');
      void detailPanel.offsetWidth;
      detailPanel.classList.add('is-collapsing');
      closeTimer = window.setTimeout(() => {
        detailPanel.hidden = true;
        detailPanel.classList.remove('is-collapsing');
      }, 220);
    }

    function expandCard(card, idx) {
      window.clearTimeout(closeTimer);
      resetCards();
      card.classList.add('is-expanded');
      selectedGrid?.classList.add('has-expanded');
      detailImage.src = card.dataset.image || '';
      detailImage.alt = card.dataset.name || '';
      detailVenue.textContent = card.dataset.venue || '';
      detailTitle.textContent = card.dataset.name || '';
      detailText.textContent = card.dataset.detail || '';
      detailKeywords.textContent = card.dataset.keywords || '';
      detailLink.href = card.dataset.href || '#';
      const rowStart = Math.floor(idx / 3) * 3;
      const rowEnd = Math.min(rowStart + 3, selectedCards.length);
      const anchor = selectedCards[rowEnd - 1];
      anchor.insertAdjacentElement('afterend', detailPanel);
      detailPanel.classList.remove('is-collapsing');
      detailPanel.hidden = false;
    }

    selectedCards.forEach((card, idx) => {
      card.addEventListener('mouseenter', () => expandCard(card, idx));
      card.addEventListener('mouseleave', () => {
        closeTimer = window.setTimeout(() => collapseDetail(true), 120);
      });
    });

    detailPanel.addEventListener('mouseenter', () => window.clearTimeout(closeTimer));
    detailPanel.addEventListener('mouseleave', () => collapseDetail(true));

    document.querySelectorAll('.repo-card[data-href]').forEach((card) => {
      card.addEventListener('click', (event) => {
        const target = event.target;
        if (target instanceof Element && target.closest('.star-link')) return;
        const href = card.getAttribute('data-href');
        if (href) window.open(href, '_blank', 'noopener');
      });
      card.addEventListener('keydown', (event) => {
        if (event.key === 'Enter' || event.key === ' ') {
          event.preventDefault();
          const href = card.getAttribute('data-href');
          if (href) window.open(href, '_blank', 'noopener');
        }
      });
    });
  </script>

  <script>
    const selectedCards = Array.from(document.querySelectorAll('[data-expand-card]'));
    const detailPanel = document.getElementById('selected-detail-panel');
    const selectedGrid = document.getElementById('selected-grid');
    const detailImage = document.getElementById('detail-image');
    const detailVenue = document.getElementById('detail-venue');
    const detailTitle = document.getElementById('detail-title');
    const detailText = document.getElementById('detail-text');
    const detailKeywords = document.getElementById('detail-keywords');
    const detailLink = document.getElementById('detail-link');

    selectedCards.forEach((card, idx) => {
      const btn = card.querySelector('.expand-btn');
      btn?.addEventListener('click', () => {
        const isOpen = card.classList.contains('is-expanded');
        selectedCards.forEach((c) => {
          c.classList.remove('is-expanded');
          const b = c.querySelector('.expand-btn');
          if (b) {
            b.setAttribute('aria-expanded', 'false');
            b.innerHTML = '<i class="fas fa-hand-pointer"></i><span>Expand</span>';
          }
        });

        if (isOpen) {
          detailPanel.hidden = true;
          selectedGrid?.classList.remove('has-expanded');
          return;
        }

        card.classList.add('is-expanded');
        btn.setAttribute('aria-expanded', 'true');
        btn.textContent = 'Collapse';

        detailImage.src = card.dataset.image || '';
        detailImage.alt = card.dataset.name || '';
        detailVenue.textContent = card.dataset.venue || '';
        detailTitle.textContent = card.dataset.name || '';
        detailText.textContent = card.dataset.detail || '';
        detailKeywords.textContent = card.dataset.keywords || '';
        detailLink.href = card.dataset.href || '#';
        selectedGrid?.classList.add('has-expanded');

        const rowStart = Math.floor(idx / 3) * 3;
        const rowEnd = Math.min(rowStart + 3, selectedCards.length);
        const anchor = selectedCards[rowEnd - 1];
        anchor.insertAdjacentElement('afterend', detailPanel);
        detailPanel.hidden = false;
      });
    });
  </script>
</Layout>

<style>
  :root { --accent: #2563eb; --accent-soft: #dbeafe; --ink: #0f172a; --muted: #475569; --page: #ffffff; }
  body { background: var(--page); }
  .container { max-width: 1800px; margin: 0 auto; padding: 20px; }
  .card { background: rgba(255,255,255,0.92); border: 1px solid rgba(148,163,184,0.12); border-radius: 18px; box-shadow: 0 10px 30px rgba(15,23,42,0.06); backdrop-filter: blur(10px); }
  .top-nav { margin-bottom: 14px; padding: 10px 0 14px; display: flex; flex-wrap: wrap; gap: 8px; align-items: center; background: transparent; border: none; border-bottom: none; border-radius: 0; box-shadow: none; }
  .top-nav a { text-decoration: none; color: var(--ink); font-family: 'Montserrat', sans-serif; font-size: 0.9rem; padding: 7px 10px; border-radius: 999px; background: transparent; }
  .top-nav a:hover { background: var(--accent-soft); color: var(--accent); }
  .top-nav a[aria-current="page"] { background: #eef2ff; color: var(--accent); box-shadow: inset 0 1px 2px rgba(15,23,42,0.10), inset 0 -1px 2px rgba(37,99,235,0.08); }
  .nav-ghost { font-size: 0.78rem; margin-left: 4px; opacity: .85; }
  .grid-2 { display: grid; grid-template-columns: 1.1fr 3.9fr; gap: 28px; align-items: start; }
  .module { padding: 16px; margin-bottom: 14px; }
  .profile, .hero-module, .accent, .direction, .placeholder, .repo-card, .note-card { background: #fff; }
  .avatar { width: 100%; height: auto; aspect-ratio: 1 / 1; border-radius: 16px; object-fit: cover; border: none; }
  h1, h2, h3 { font-family: Montserrat, sans-serif; font-weight: 700; }
  h1 { font-size: 1.9rem; margin: 12px 0 4px; }
  .name-en { font-size: 2rem; letter-spacing: .01em; text-align: center; }
  .name-zh { margin: 2px 0 0; font-size: 1rem; color: #334155; display: inline-flex; align-items: center; justify-content: center; gap: 6px; width: 100%; text-align: center; }
  .name-tip { position: relative; display: inline-flex; align-items: center; justify-content: center; width: 16px; height: 16px; border-radius: 999px; background: #cbd5e1; color: #0f172a; font-size: .72rem; line-height: 1; cursor: help; }
  .tip-pop { position: absolute; left: 22px; top: 50%; transform: translateY(-50%); white-space: nowrap; background: #0f172a; color: #fff; padding: 4px 8px; border-radius: 6px; font-size: .72rem; opacity: 0; pointer-events: none; transition: opacity .15s ease; }
  .name-tip:hover .tip-pop, .name-tip:focus .tip-pop { opacity: 1; }
  .role { margin: 0; color: #334155; font-size: .92rem; text-align: center; }
  .bio { text-align: left; color: #334155; font-size: .92rem; margin-top: 10px; }
  .icons { display: flex; flex-wrap: wrap; justify-content: center; gap: 6px; margin-top: 14px; }
  .icons a { color: #334155; text-decoration: none; transition: color .15s ease, transform .15s ease; }
  .icons a:hover { color: #0f172a; transform: translateY(-1px); }
  .icons i { font-size: 1.95rem; }
  h2 { font-size: 1.2rem; margin: 0 0 12px; }
  h3 { font-size: 1rem; margin: 0 0 6px; }
  .updates { list-style: none; padding-left: 0; display: grid; gap: 8px; }
