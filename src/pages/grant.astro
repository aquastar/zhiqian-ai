---
import Layout from '../layouts/Layout.astro';

const externalGrants = [
  {
    agency: 'NSF', logo: '/icons/nsf.svg',
    title: 'NSF CAREER: From Fragmentation to Integration: Advancing Cross-Graph Dynamics in Interdependent Networks',
    awardNo: '#2443266', period: '06/2025–05/2030', amount: '$517,594', role: 'Sole PI',
    desc: 'CAREER project on unification and interactions across graph dynamics in interdependent networks.',
    link: 'https://www.nsf.gov/awardsearch/showAward?AWD_ID=2443266',
  },
  {
    agency: 'NSF', logo: '/icons/nsf.svg',
    title: 'NSF CISE MSI: RCBP: III: Advancing Speech Detection: A Hybrid Approach Using Large Language Models and Graph Neural Networks',
    awardNo: '#2431176', period: '01/2025–12/2026', amount: '$400,000', role: 'Co-PI / University PI',
    desc: 'Speech detection using LLMs and graph neural networks.',
    link: 'https://www.nsf.gov/awardsearch/showAward?AWD_ID=2431176&HistoricalAwards=false',
  },
  {
    agency: 'NSF', logo: '/icons/nsf.svg',
    title: 'NSF CIRC: Planning-C: Synergistic Graph Flow Analytics: An Integrated Infrastructure for Bridging Complexity, Fragmentation, and Interdisciplinary Gaps',
    awardNo: '#2345921', period: '07/2024–06/2025', amount: '$99,998', role: 'PI',
    desc: 'Planning-C project on graph flow analytics and integrated infrastructure.',
    link: 'https://www.nsf.gov/awardsearch/showAward?AWD_ID=2345921&HistoricalAwards=false',
  },
  {
    agency: 'NSF', logo: '/icons/nsf.svg',
    title: 'NSF CRII: Interpretable Influence Propagating and Blocking on Graphs',
    awardNo: '#2153369', period: '05/2022–11/2024', amount: '$174,004', role: 'Sole PI',
    desc: 'CRII project on interpretable influence propagation and blocking on graphs.',
    link: 'https://www.nsf.gov/awardsearch/showAward?AWD_ID=2153369&HistoricalAwards=false',
  },
  {
    agency: 'NSF', logo: '/icons/nsf.svg',
    title: 'ITEST: Learning to Create Intelligent Solutions with Machine Learning and Computer Vision: A Pathway to AI Careers for Diverse High School Students',
    awardNo: '#2342574', period: '09/2024–08/2027', amount: '$1,192,951', role: 'Co-PI',
    desc: 'AI education and pathway-building program for diverse high school students.',
    link: 'https://www.nsf.gov/awardsearch/showAward?AWD_ID=2342574',
  },
  {
    agency: 'Turing AI', logo: '/icons/turing_ai.svg',
    title: 'Turing AI Gift Money',
    awardNo: '', period: '08/2025', amount: '$25,000', role: 'Gift Funding',
    desc: 'Gift support for LLM-related research.',
    link: '',
  },
  {
    agency: 'USDA-ARS', logo: '/icons/usda.svg',
    title: 'Developing Detection and Modeling Tools for the Geospatial and Environmental Epidemiology of Animal Disease',
    awardNo: '#58-6064-3-017', period: '10/2023–08/2028', amount: '$3,073,602', role: 'Co-PI',
    desc: 'Detection and modeling tools for animal disease epidemiology.',
    link: 'https://imczq.com/',
  },
  {
    agency: 'USDA-ARS', logo: '/icons/usda.svg',
    title: 'Advancing Agricultural Research through High Performance Computing',
    awardNo: '#58-0200-0-002', period: '10/2022–08/2024', amount: '$5,690,689', role: 'Co-PI',
    desc: 'Agricultural research enabled by HPC infrastructure and collaboration.',
    link: 'https://imczq.com/',
  },
  {
    agency: 'NSF', logo: '/icons/nsf.svg',
    title: 'REU Supplementary',
    awardNo: '', period: '11/2023–11/2024', amount: '$14,000', role: 'PI',
    desc: 'Supplementary undergraduate research support.',
    link: '',
  },
  {
    agency: 'USDA-ARS', logo: '/icons/usda.svg',
    title: 'Summer Internship Project',
    awardNo: '', period: '05/2024–04/2025', amount: '$8,199', role: 'PI',
    desc: 'Summer internship support connected to USDA research activity.',
    link: '',
  },
];

const internalSupport = [
  {
    agency: 'MS State', logo: '/icons/mississippi_state.svg',
    title: 'Ottilie Schillig Special Teaching Award',
    period: '2025', amount: '$2,994.50', role: 'PI',
    desc: 'Internal teaching award support through the Center for Teaching and Learning.',
    link: 'https://www.ctl.msstate.edu/resources/ottilie-schillig-special-teaching-projects-grants',
  },
  {
    agency: 'MS State', logo: '/icons/mississippi_state.svg',
    title: 'Global Development Seed Grant Award',
    period: '2025', amount: '$6,000', role: 'PI',
    desc: 'Internal seed grant support through the International Institute.',
    link: '',
  },
  {
    agency: 'MS State', logo: '/icons/mississippi_state.svg',
    title: 'Working Group in Graph AI',
    period: '2023', amount: '$4,100', role: 'PI',
    desc: 'Internal support from Bagley College of Engineering.',
    link: '',
  },
  {
    agency: 'MS State', logo: '/icons/mississippi_state.svg',
    title: 'Undergrad Research Program',
    period: '2022 / 2023 / 2024 / 2025', amount: '$2,000 (2022/2024/2025), $1,500 (2023)', role: 'PI / Co-PI',
    desc: 'Office of Research and Economic Development undergraduate research support.',
    link: '',
  },
];
---
<Layout title="Grant | Zhiqian Chen">
  <main class="container">
    <nav class="top-nav" aria-label="Sections">
      <a href="/">Home</a>
      <a href="/research">Research</a>
      <a href="/people">People</a>
      <a href="/teach">Teach</a>
      <a href="/grant" aria-current="page">Grant</a>
      <a href="https://scholar.google.com/scholar?q=Zhiqian+Chen" target="_blank" rel="noopener">Paper <i class="fas fa-arrow-up-right-from-square nav-ghost"></i></a>
      <a href="https://zhiqian.ai" target="_blank" rel="noopener">Zhiqian.ai <i class="fas fa-arrow-up-right-from-square nav-ghost"></i></a>
    </nav>

    <section class="hero">
      <h1>Grant</h1>
      <p>Selected external funding and internal support.</p>
    </section>

    <section class="section">
      <h2>External</h2>
      <div class="list">
        {externalGrants.map((g) => {
          const RowTag = g.link ? 'a' : 'article';
          return (
            <RowTag class="grant-row" href={g.link || undefined} target={g.link ? '_blank' : undefined} rel={g.link ? 'noopener' : undefined}>
              <div class="logo-box external"><img src={g.logo} alt={g.agency} loading="lazy" /></div>
              <div class="content">
                <h3>{g.title}</h3>
                <p class="meta">{g.awardNo ? `${g.awardNo} · ` : ''}{g.period} · {g.amount} · {g.role}</p>
                <p class="desc">{g.desc}</p>
              </div>
            </RowTag>
          );
        })}
      </div>
    </section>

    <section class="section">
      <h2>Internal</h2>
      <div class="list">
        {internalSupport.map((g) => {
          const RowTag = g.link ? 'a' : 'article';
          return (
            <RowTag class="grant-row" href={g.link || undefined} target={g.link ? '_blank' : undefined} rel={g.link ? 'noopener' : undefined}>
              <div class="logo-box internal"><img src={g.logo} alt={g.agency} loading="lazy" /></div>
              <div class="content">
                <h3>{g.title}</h3>
                <p class="meta">{g.period} · {g.amount} · {g.role}</p>
                <p class="desc">{g.desc}</p>
              </div>
            </RowTag>
          );
        })}
      </div>
    </section>
  </main>
</Layout>

<style>
  :root { --accent:#2563eb; --ink:#0f172a; --muted:#475569; }
  .container { max-width: 1800px; margin: 0 auto; padding: 20px; }
  .top-nav { margin-bottom: 14px; padding: 10px 0 14px; display:flex; flex-wrap:wrap; gap:8px; align-items:center; background:transparent; border:none; border-bottom:none; border-radius:0; box-shadow:none; }
  .top-nav a { text-decoration:none; color:var(--ink); font-family:'Montserrat',sans-serif; font-size:.9rem; padding:7px 10px; border-radius:999px; background:transparent; }
  .top-nav a:hover { background:#dbeafe; color:var(--accent); }
  .nav-ghost { font-size:.78rem; margin-left:4px; opacity:.85; }
  .hero { margin: 10px 0 18px; }
  .hero h1 { font-family:'Montserrat',sans-serif; font-size:2rem; margin:0 0 8px; }
  .hero p { margin:0; color:var(--muted); }
  .section { margin-top: 18px; }
  .section h2 { font-family:'Montserrat',sans-serif; font-size:1rem; margin:0 0 10px; }
  .list { display:grid; gap:10px; }
  .grant-row {
    display:grid;
    grid-template-columns: 60px 1fr;
    gap:12px;
    align-items:start;
    border:1px solid rgba(148,163,184,.14);
    border-radius:12px;
    background:#fff;
    padding:10px 12px;
    text-decoration:none;
    color:inherit;
    transition:transform .16s ease, box-shadow .16s ease, border-color .16s ease;
  }
  .grant-row:hover {
    transform: translateY(-1px);
    box-shadow: 0 10px 20px rgba(15,23,42,0.06);
    border-color: rgba(37,99,235,0.24);
  }
  .logo-box {
    width:60px;
    height:60px;
    display:flex;
    align-items:center;
    justify-content:center;
    overflow:hidden;
    border-radius:10px;
    background:#fff;
  }
  .logo-box.external img { width:100%; height:100%; object-fit:contain; }
  .logo-box.internal img { width:100%; height:100%; object-fit:contain; }
  .content h3 {
    margin:0 0 4px;
    font-family:'Montserrat',sans-serif;
    font-size:.95rem;
    line-height:1.25;
  }
  .meta {
    margin:0 0 4px;
    font-size:.8rem;
    color:#334155;
    line-height:1.25;
  }
  .desc {
    margin:0;
    font-size:.82rem;
    color:#64748b;
    line-height:1.32;
  }
  @media (max-width: 720px) {
    .grant-row { grid-template-columns: 60px 1fr; gap:10px; padding:10px; }
    .logo-box { width:60px; height:60px; }
    .content h3 { font-size:.88rem; }
    .meta, .desc { font-size:.76rem; }
  }
</style>
