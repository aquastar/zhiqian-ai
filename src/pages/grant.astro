    awardNo: '#2443266', period: '06/2025–05/2030', amount: '$517,594', credit: '100% credit', role: 'Sole PI',
    collaborators: 'Mississippi State University',
    desc: 'CAREER project on unification and interactions across graph dynamics in interdependent networks.',
    link: 'https://www.nsf.gov/awardsearch/showAward?AWD_ID=2443266',
  },
  {
    kind: 'External', agency: 'NSF', logo: '/icons/nsf.svg',
    title: 'NSF CISE MSI: RCBP: III: Advancing Speech Detection: A Hybrid Approach Using Large Language Models and Graph Neural Networks',
