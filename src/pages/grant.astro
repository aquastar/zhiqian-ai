---
<Layout title="Grant | Zhiqian Chen">
  <main class="container">
    <nav class="top-nav" aria-label="Sections">
      <a href="/">Home</a>
      <a href="/research">Research</a>
      <a href="/people">People</a>
      <a href="/teach">Teach</a>
      <a href="/grant" aria-current="page">Grant</a>
      <a href="https://scholar.google.com/scholar?q=Zhiqian+Chen" target="_blank" rel="noopener">Paper <i class="fas fa-arrow-up-right-from-square nav-ghost"></i></a>
      <a href="https://zhiqian.ai" target="_blank" rel="noopener">Zhiqian.ai <i class="fas fa-arrow-up-right-from-square nav-ghost"></i></a>
    </nav>

    <section class="hero">
      <h1>Grant</h1>
      <p>Complete funding list adapted from the grants section of cv.pdf.</p>
    </section>

    <section class="summary-grid">
      <article class="summary-card">
        <span class="summary-label">Personal Credits</span>
        <strong>{totals.personal}</strong>
      </article>
      <article class="summary-card">
        <span class="summary-label">Total External</span>
        <strong>{totals.external}</strong>
      </article>
      <article class="summary-card">
        <span class="summary-label">Total Internal</span>
        <strong>{totals.internal}</strong>
      </article>
    </section>

    <section class="section">
      <h2>Complete Grant List</h2>
      <div class="cards three">
        {grants.map((g) => (
          <article class="card">
            <div class="card-top">
              <div class={`agency-mark ${g.kind.toLowerCase()}`}>
                <img src={g.logo} alt={g.agency} loading="lazy" />
              </div>
              <div class="top-meta">
                <span class={`kind ${g.kind.toLowerCase()}`}>{g.kind}</span>
                <span class="tag">{g.agency}</span>
              </div>
            </div>
            <h3>{g.title}</h3>
            <div class="facts">
              {g.awardNo && <p><strong>Award:</strong> {g.awardNo}</p>}
              <p><strong>Period:</strong> {g.period}</p>
              <p><strong>Amount:</strong> {g.amount}</p>
              {g.credit && <p><strong>Credit:</strong> {g.credit}</p>}
              <p><strong>Role:</strong> {g.role}</p>
              <p><strong>Collaborators:</strong> {g.collaborators}</p>
            </div>
            <p class="desc">{g.desc}</p>
            {g.link && (
              <p class="link-row"><a href={g.link} target="_blank" rel="noopener">Source <i class="fas fa-arrow-up-right-from-square"></i></a></p>
            )}
          </article>
        ))}
      </div>
    </section>
  </main>
</Layout>

<style>
  :root { --accent:#2563eb; --ink:#0f172a; --muted:#475569; }
  .container { max-width: 1800px; margin: 0 auto; padding: 20px; }
  .top-nav { margin-bottom: 14px; padding: 10px 0 14px; display:flex; flex-wrap:wrap; gap:8px; align-items:center; background:transparent; border:none; border-bottom:none; border-radius:0; box-shadow:none; }
  .top-nav a { text-decoration:none; color:var(--ink); font-family:'Montserrat',sans-serif; font-size:.9rem; padding:7px 10px; border-radius:999px; background:transparent; }
  .top-nav a:hover { background:#dbeafe; color:var(--accent); }
  .nav-ghost { font-size:.78rem; margin-left:4px; opacity:.85; }
  .hero { margin: 10px 0 16px; }
  .hero h1 { font-family:'Montserrat',sans-serif; font-size:2rem; margin:0 0 8px; }
  .hero p { margin:0; color:var(--muted); max-width:780px; }
  .summary-grid { display:grid; grid-template-columns: repeat(3, minmax(0,1fr)); gap:10px; margin: 0 0 14px; }
  .summary-card { border:1px solid rgba(148,163,184,.14); border-radius:12px; background:#fff; padding:12px 14px; }
  .summary-label { display:block; font-size:.78rem; color:#64748b; margin-bottom:4px; }
  .summary-card strong { font-size:1rem; color:#0f172a; }
  .section { padding-top:8px; margin-top:8px; border-top:none; }
  .section h2 { font-family:'Montserrat',sans-serif; font-size:1.02rem; margin:0 0 10px; }
  .cards { display:grid; gap:10px; }
  .cards.three { grid-template-columns: repeat(3, minmax(0,1fr)); }
  .card { border:1px solid rgba(148,163,184,.14); border-radius:12px; background:#fff; padding:12px; }
  .card-top { display:flex; align-items:flex-start; gap:8px; margin-bottom:8px; }
  .agency-mark { width:48px; height:48px; border-radius:10px; background:#ffffff; display:flex; align-items:center; justify-content:center; flex:0 0 auto; overflow:hidden; }
  .agency-mark.external img { width:100%; height:100%; object-fit:contain; display:block; }
  .agency-mark.internal { width:72px; height:50px; padding:4px; }
  .agency-mark.internal img { width:100%; height:100%; object-fit:contain; display:block; }
  .top-meta { display:flex; flex-wrap:wrap; gap:6px; align-items:center; }
  .card h3 { font-family:'Montserrat',sans-serif; font-size:.9rem; margin:0 0 6px; line-height:1.24; }
  .facts { display:grid; gap:3px; margin-bottom:8px; }
  .facts p, .desc { margin:0; color:#334155; font-size:.78rem; line-height:1.32; }
  .desc { color:#475569; }
  .link-row { margin-top:8px !important; }
  .link-row a { color:var(--accent); text-decoration:none; font-size:.78rem; }
  .link-row a:hover { text-decoration:underline; }
  .tag { display:inline-block; font-size:.64rem; color:var(--accent); background:#dbeafe; padding:2px 6px; border-radius:999px; }
  .kind { display:inline-block; font-size:.62rem; font-weight:700; text-transform:uppercase; letter-spacing:.03em; padding:2px 6px; border-radius:999px; }
  .kind.external { background:#dcfce7; color:#166534; }
  .kind.internal { background:#fef3c7; color:#92400e; }
  @media (max-width: 1100px) { .cards.three, .summary-grid { grid-template-columns: repeat(2, minmax(0,1fr)); } }
  @media (max-width: 720px) { .cards.three, .summary-grid { grid-template-columns:1fr; } }
</style>
