                    <img src={`https://img.shields.io/badge/${encodeURIComponent(repo.owner)}-f8fafc.svg?style=flat-square&logo=github&logoColor=181717&labelColor=f8fafc&color=f8fafc`} alt={`owner ${repo.owner}`} />
                    <img src={`https://img.shields.io/badge/${encodeURIComponent(repo.language)}-f8fafc.svg?style=flat-square&logo=python&logoColor=3776AB&labelColor=f8fafc&color=f8fafc`} alt={`language ${repo.language}`} />
                    <iframe class="github-star-btn" src={`https://ghbtns.com/github-btn.html?user=${repo.owner}&repo=${repo.repo}&type=star&count=true&size=small`} title={`Star ${repo.name} on GitHub`} width="96" height="20"></iframe>
                  </div>
                </article>
              ))}
            </div>
          </article>

          <article class="card module ghost-card" id="ghost-entries">
            <h2>Tech Notes</h2>
            <div class="stack dense one-col">
              {ghostEntries.map((entry) => (
                <div class="mini-card note-card placeholder">
                  <div class="row"><h3>{entry.title}</h3><span class="repo-pill muted">{entry.meta}</span></div>
                  <p>{entry.desc}</p>
                </div>
              ))}
            </div>
          </article>
        </section>
      </section>
  </main>

  <script>
    const navToggle = document.querySelector('.nav-toggle');
    const topNav = document.querySelector('.top-nav');
    navToggle?.addEventListener('click', () => {
      const open = topNav?.classList.toggle('nav-open');
      navToggle.setAttribute('aria-expanded', open ? 'true' : 'false');
    });
    document.querySelectorAll('.nav-links a').forEach((link) => {
      link.addEventListener('click', () => {
        topNav?.classList.remove('nav-open');
        navToggle?.setAttribute('aria-expanded', 'false');
      });
    });


    const selectedFilterButtons = Array.from(document.querySelectorAll('[data-selected-filter]'));
    const selectedEntries = Array.from(document.querySelectorAll('#selected-list .citation-entry'));
    const flowSteps = Array.from(document.querySelectorAll('[data-flow]'));
    const pillarCards = Array.from(document.querySelectorAll('[data-pillar]'));

    const applySelectedFilter = (button) => {
      const filter = button.getAttribute('data-selected-filter') || 'all';
      selectedFilterButtons.forEach((btn) => {
        const active = btn === button;
        btn.classList.toggle('is-active', active);
        btn.setAttribute('aria-pressed', active ? 'true' : 'false');
      });
      selectedEntries.forEach((entry) => {
        const matches = filter === 'all' || entry.getAttribute('data-direction') === filter;
        entry.hidden = !matches;
      });
    };

    selectedFilterButtons.forEach((button) => {
      button.addEventListener('mouseenter', () => applySelectedFilter(button));
      button.addEventListener('focus', () => applySelectedFilter(button));
      button.addEventListener('click', () => applySelectedFilter(button));
    });

    const setFlowHighlight = (key) => {
      flowSteps.forEach((step) => step.classList.toggle('is-active', step.getAttribute('data-flow') === key));
      pillarCards.forEach((card) => {
        const groups = (card.getAttribute('data-pillar') || '').split(/\s+/).filter(Boolean);
        card.classList.toggle('is-dim', !!key && !groups.includes(key));
        card.classList.toggle('is-active', !!key && groups.includes(key));
      });
    };

    flowSteps.forEach((step) => {
      const key = step.getAttribute('data-flow');
      step.addEventListener('mouseenter', () => setFlowHighlight(key));
      step.addEventListener('focusin', () => setFlowHighlight(key));
      step.addEventListener('mouseleave', () => setFlowHighlight(null));
      step.addEventListener('focusout', () => setFlowHighlight(null));
    });

    const updatesMoreBtn = document.getElementById('updates-more-btn');
    const extraUpdates = Array.from(document.querySelectorAll('[data-extra-update="true"]'));
    let updatesExpanded = false;

    updatesMoreBtn?.addEventListener('click', () => {
      updatesExpanded = !updatesExpanded;
      extraUpdates.forEach((item) => {
        item.classList.toggle('update-hidden', !updatesExpanded);
      });
      updatesMoreBtn.textContent = updatesExpanded ? 'Collapse' : 'More';
    });

    document.querySelectorAll('.repo-card[data-href]').forEach((card) => {
      card.addEventListener('click', (event) => {
        const target = event.target;
        if (target instanceof Element && target.closest('.github-star-btn')) return;
        const href = card.getAttribute('data-href');
        if (href) window.open(href, '_blank', 'noopener');
      });
      card.addEventListener('keydown', (event) => {
        if (event.key === 'Enter' || event.key === ' ') {
          event.preventDefault();
          const href = card.getAttribute('data-href');
          if (href) window.open(href, '_blank', 'noopener');
        }
      });
    });
  </script>
</Layout>

