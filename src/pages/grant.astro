    desc: 'Speech detection using LLMs and graph neural networks.',
    link: 'https://www.nsf.gov/awardsearch/showAward?AWD_ID=2431176&HistoricalAwards=false',
  },
  {
    kind: 'External', agency: 'NSF', logo: '/icons/nsf.svg',
    title: 'NSF CIRC: Planning-C: Synergistic Graph Flow Analytics: An Integrated Infrastructure for Bridging Complexity, Fragmentation, and Interdisciplinary Gaps',
    awardNo: '#2345921', period: '07/2024–06/2025', amount: '$99,998', credit: '60% credit', role: 'PI',
    collaborators: 'Mississippi State University',
    desc: 'Planning-C project on graph flow analytics and integrated infrastructure.',
    link: 'https://www.nsf.gov/awardsearch/showAward?AWD_ID=2345921&HistoricalAwards=false',
  },
  {
    kind: 'External', agency: 'NSF', logo: '/icons/nsf.svg',
    title: 'NSF CRII: Interpretable Influence Propagating and Blocking on Graphs',
    awardNo: '#2153369', period: '05/2022–11/2024', amount: '$174,004', credit: '100% credit', role: 'Sole PI',
    collaborators: 'Mississippi State University',
    desc: 'CRII project on interpretable influence propagation and blocking on graphs.',
    link: 'https://www.nsf.gov/awardsearch/showAward?AWD_ID=2153369&HistoricalAwards=false',
  },
  {
    kind: 'External', agency: 'USDA-ARS', logo: '/icons/usda.svg',
    title: 'Developing Detection and Modeling Tools for the Geospatial and Environmental Epidemiology of Animal Disease',
    awardNo: '#58-6064-3-017', period: '10/2023–08/2028', amount: '$3,073,602', credit: '5% credit', role: 'Co-PI',
    collaborators: 'USDA-ARS + Mississippi State University',
    desc: 'Detection and modeling tools for animal disease epidemiology.',
    link: 'https://imczq.com/',
  },
  {
    kind: 'External', agency: 'USDA-ARS', logo: '/icons/usda.svg',
    title: 'Advancing Agricultural Research through High Performance Computing',
    awardNo: '#58-0200-0-002', period: '10/2022–08/2024', amount: '$5,690,689', credit: '5% credit', role: 'Co-PI',
    collaborators: 'USDA-ARS + Mississippi State University',
    desc: 'Agricultural research enabled by HPC infrastructure and collaboration.',
    link: 'https://imczq.com/',
  },
  {
    kind: 'External', agency: 'NSF [EDU]', logo: '/icons/nsf.svg',
    title: 'ITEST: Learning to Create Intelligent Solutions with Machine Learning and Computer Vision: A Pathway to AI Careers for Diverse High School Students',
    awardNo: '#2342574', period: '09/2024–08/2027', amount: '$1,192,951', credit: '25% credit', role: 'Co-PI',
    collaborators: 'Mississippi State University + K-12 partners',
    desc: 'AI education and pathway-building program for diverse high school students.',
    link: 'https://www.nsf.gov/awardsearch/showAward?AWD_ID=2342574',
  },
  {
    kind: 'External', agency: 'Turing AI', logo: '/icons/turing_ai.svg',
    title: 'Turing AI Gift Money',
    awardNo: '', period: '08/2025', amount: '$25,000', credit: '100% credit', role: 'Gift Funding',
    collaborators: 'Mississippi State University',
    desc: 'Gift support for LLM-related research.',
    link: '',
  },
  {
    kind: 'External', agency: 'NSF [III]', logo: '/icons/nsf.svg',
    title: 'REU Supplementary',
    awardNo: '', period: '11/2023–11/2024', amount: '$14,000', credit: '100% credit', role: 'PI',
    collaborators: 'Mississippi State University',
    desc: 'Supplementary undergraduate research support.',
    link: '',
  },
  {
    kind: 'External', agency: 'USDA [ARS]', logo: '/icons/usda.svg',
    title: 'Summer Internship Project',
    awardNo: '', period: '05/2024–04/2025', amount: '$8,199', credit: '100% credit', role: 'PI',
    collaborators: 'USDA-ARS + Mississippi State University',
