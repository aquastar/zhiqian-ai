    awardNo: '', period: '11/2024–11/2026', amount: '$5,000', credit: '100% credit', role: 'Sole PI',
    collaborators: 'Google Cloud + Mississippi State University',
    desc: 'Research cloud credits for project development and experimentation.',
    link: '',
  },
  {
    kind: 'Internal', agency: 'CTL', logo: '/icons/msstate.svg',
    title: 'Ottilie Schillig Special Teaching Award',
    awardNo: '', period: '2025', amount: '$2,994.50', credit: '', role: 'PI',
    collaborators: 'Center for Teaching and Learning, Mississippi State University',
    desc: 'Internal teaching award support.',
    link: 'https://www.ctl.msstate.edu/resources/ottilie-schillig-special-teaching-projects-grants',
  },
  {
    kind: 'Internal', agency: 'Inter-Ins', logo: '/icons/msstate.svg',
    title: 'Global Development Seed Grant Award',
    awardNo: '', period: '2025', amount: '$6,000', credit: '', role: 'PI',
    collaborators: 'International Institute',
    desc: 'Internal seed grant support for global development activity.',
    link: '',
  },
  {
    kind: 'Internal', agency: 'Bagley', logo: '/icons/msstate.svg',
    title: 'Working Group in Graph AI',
    awardNo: '', period: '2023', amount: '$4,100', credit: '', role: 'PI',
    collaborators: 'Bagley College of Engineering',
    desc: 'Internal support for a Graph AI working group.',
    link: '',
  },
  {
    kind: 'Internal', agency: 'ORED', logo: '/icons/msstate.svg',
    title: 'Undergrad Research Program',
    awardNo: '', period: '2022 / 2023 / 2024 / 2025', amount: '$2,000 (2022/2024/2025), $1,500 (2023)', credit: '', role: 'PI / Co-PI',
    collaborators: 'Office of Research and Economic Development',
    desc: 'Undergraduate research program support across multiple years.',
    link: '',
