const parseBibtexField = (bibtex, field) => {
  const match = bibtex?.match(new RegExp(`(?:^|[\\s,{])${field}\\s*=\\s*\\{([^}]*)\\}`, 'i'));
  return match?.[1]?.trim() ?? '';
};

const normalizeAuthorName = (name) => {
  const trimmed = name.trim();
  if (!trimmed.includes(',')) return trimmed;
  const [last, first] = trimmed.split(',').map((part) => part.trim());
  return [first, last].filter(Boolean).join(' ');
};

const formatChicagoAuthors = (authorsRaw, fallback = 'Zhiqian Chen') => {
  const authors = authorsRaw
    .split(/\s+and\s+/i)
    .map((name) => normalizeAuthorName(name))
    .filter(Boolean);

  if (!authors.length) return fallback;
  if (authors.length === 1) return authors[0];
  if (authors.length === 2) return `${authors[0]} and ${authors[1]}`;
  return `${authors.slice(0, -1).join(', ')}, and ${authors[authors.length - 1]}`;
};

const formatChicagoCitation = (work) => {
  const authorsRaw = parseBibtexField(work.bibtex, 'author');
  const titleRaw = parseBibtexField(work.bibtex, 'title');
  const booktitleRaw = parseBibtexField(work.bibtex, 'booktitle');
  const journalRaw = parseBibtexField(work.bibtex, 'journal');

  const authors = formatChicagoAuthors(authorsRaw);
  const venue = journalRaw || booktitleRaw || `${work.venue} ${work.year}`;
  const title = titleRaw || work.name;

  return {
    authors,
    title,
    venue,
    year: work.year,
  };
};

